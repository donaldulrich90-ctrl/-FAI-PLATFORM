# Copiez ce fichier vers .env et adaptez les valeurs.
# Docker Compose charge automatiquement .env à la racine du projet.

# --- Base PostgreSQL (conteneur db) ---
POSTGRES_DB=faso_isp
POSTGRES_USER=faso_isp
POSTGRES_PASSWORD=changez-moi-mot-de-passe-fort

# --- Django ---
# OBLIGATOIRE en production : chaîne longue et aléatoire
DJANGO_SECRET_KEY=remplacer-par-une-cle-longue-et-aleatoire

# 1 = développement (runserver si compose dev), 0 = production (gunicorn + collectstatic)
DJANGO_DEBUG=0

# --- Compte admin automatique (développement / premier login) ---
# Si DJANGO_BOOTSTRAP_ADMIN_PASSWORD est non vide, migrate + entrypoint exécutent
# « python manage.py bootstrap_admin » : crée ou met à jour le superuser (défaut : demo).
# Autorisé seulement si DJANGO_DEBUG=1 OU DJANGO_ALLOW_BOOTSTRAP_ADMIN=1 (jamais en prod sans réflexion).
# DJANGO_BOOTSTRAP_ADMIN_USERNAME=demo
# DJANGO_BOOTSTRAP_ADMIN_PASSWORD=choisir-un-mot-de-passe-local-fort
# DJANGO_BOOTSTRAP_ADMIN_EMAIL=
# DJANGO_ALLOW_BOOTSTRAP_ADMIN=0

# Local : localhost,127.0.0.1,web
# VPS : votre domaine ou IP + web (nom du service Docker)
# Exemple : monispe.example.com,127.0.0.1,web
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web

# HTTPS (VPS derrière Nginx / Caddy) : origines complètes, séparées par des virgules
# Exemple : https://monisp.example.com,https://www.monisp.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# 1 si TLS terminé par un reverse proxy (Nginx) pour les en-têtes X-Forwarded-Proto
DJANGO_BEHIND_TLS_PROXY=0

# Port publié sur l'hôte pour l'application (défaut 8000)
WEB_PUBLISH_PORT=8000

# --- SQLite rapide (sans Postgres) : uniquement pour test local hors Docker ---
# Dans run_local.ps1 ou shell : $env:USE_SQLITE="1"
# USE_SQLITE=0

# --- Zabbix (stack Docker) ---
ZABBIX_DB_PASSWORD=zabbix_db_secret
ZABBIX_API_URL=http://zabbix-web:8080/api_jsonrpc.php
ZABBIX_API_USER=Admin
ZABBIX_API_PASSWORD=zabbix

# --- Uptime Kuma : URL vue depuis le conteneur Django ---
UPTIME_KUMA_URL=http://uptime-kuma:3001

# --- SNMP ---
SNMP_COMMUNITY=public

# --- Gunicorn (production) ---
GUNICORN_WORKERS=3
